				{
					"name": "✅ Create New Customer (Fixed)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate unique data for new customer",
									"const timestamp = Date.now();",
									"const uniqueId = Math.random().toString(36).substr(2, 9);",
									"",
									"pm.environment.set('newCustomerEmail', `customer-${timestamp}@test.com`);",
									"pm.environment.set('newCustomerName', `Test Customer ${uniqueId}`);",
									"pm.environment.set('newCustomerPassword', 'senha123'); // Required field"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Customer created successfully', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData.email).to.eql(pm.environment.get('newCustomerEmail'));",
									"    ",
									"    // Store new customer ID",
									"    pm.environment.set('newCustomerId', jsonData.id);",
									"    pm.environment.set('lastCreatedCustomerId', jsonData.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"{{newCustomerName}}\",\n    \"email\": \"{{newCustomerEmail}}\",\n    \"password\": \"{{newCustomerPassword}}\",\n    \"phone\": \"(11) 99999-1234\",\n    \"address\": {\n        \"street\": \"Rua Teste\",\n        \"number\": \"456\",\n        \"complement\": \"Apt 789\",\n        \"neighborhood\": \"Vila Teste\",\n        \"city\": \"São Paulo\",\n        \"state\": \"SP\",\n        \"postalCode\": \"04567-890\",\n        \"reference\": \"Próximo ao teste\"\n    }\n}"
						},
